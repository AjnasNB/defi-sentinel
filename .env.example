# ===========================================
# DeFi Sentinel - Environment Configuration
# ===========================================

# WDK Configuration
WDK_SEED_PHRASE=your-seed-phrase-here

# EVM RPC URLs (testnet for wallet ops)
ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
POLYGON_RPC_URL=https://polygon-amoy-bor-rpc.publicnode.com
ARBITRUM_RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com

# Backend
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:3001

# Azure OpenAI (for AI agent decisions)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Agent Configuration
AGENT_INTERVAL_MS=30000
MAX_TRANSACTION_USD=100
DAILY_SPENDING_LIMIT_USD=500
MIN_YIELD_THRESHOLD_BPS=50
